# Default ignored files
/shelf/
/workspace.xml
# Ignored default folder with query files
/queries/
# Datasource local storage ignored files
/dataSources/
/dataSources.local.xml
# Editor-based HTTP Client requests
/httpRequests/
/.idea/**
*.iml

# Superpowers brainstorming visual companion
.superpowers/**
.claude/**
.devcontainer/**

# Maven
target/
*.log

# Node / Playwright
node_modules/
playwright-report/
test-results/

# Vaadin generated frontend
**/src/main/frontend/

# Vaadin frontend bundles (generated in test runtime)
**/src/main/bundles/

# Vaadin generates these in the module root during dev-mode builds
**/package.json
**/package-lock.json
**/tsconfig.json
**/types.d.ts
# ...but keep Playwright's ones in the e2e module
!e2e/src/test/playwright/package.json
!e2e/src/test/playwright/package-lock.json
!e2e/src/test/playwright/tsconfig.json
